{
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "title": "Request Rate (req/s)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "spanNulls": false,
                        "axisBorderShow": false
                    },
                    "unit": "reqps"
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rate(http_requests_total[1m])",
                    "legendFormat": "{{handler}} {{method}} {{status}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Response Time (p95)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10
                    },
                    "unit": "s"
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
                    "legendFormat": "{{handler}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Requests In Progress",
            "type": "gauge",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 10
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "http_requests_in_progress",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "HTTP Status Codes",
            "type": "piechart",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 6,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "targets": [
                {
                    "expr": "sum by (status) (increase(http_requests_total[5m]))",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Total Requests by Endpoint",
            "type": "bargauge",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "sum by (handler) (increase(http_requests_total[1h]))",
                    "legendFormat": "{{handler}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Prometheus Targets Up",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 24,
                "x": 0,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    },
                    "mappings": [
                        {
                            "options": {
                                "0": {
                                    "text": "DOWN",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            },
                            "type": "value"
                        }
                    ]
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "up",
                    "legendFormat": "{{job}}",
                    "refId": "A"
                }
            ]
        }
    ],
    "schemaVersion": 39,
    "tags": [
        "helpdesk",
        "fastapi"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-30m",
        "to": "now"
    },
    "title": "HelpDesk Monitoring",
    "uid": "helpdesk-monitoring",
    "version": 1
}